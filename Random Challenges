import random
s = True
score = 0
compscore = 0
print("You get 1 point for a win, 0 for a draw and -1 for a loss")
while s == True:
  weapons = ["rock", "paper", "scissors"]
  selected = random.choice(weapons)
  choice = input("Choose 'Rock', 'paper' or 'scissors").lower()
  print("The computer chose", selected)
  print("You chose", choice)
  if selected == choice:
    print("No-one won")
  elif (selected == "rock" and choice == "paper") or (selected == "paper" and choice == "scissors") or (selected == "scissors" and choice == "rock"):
    print("You Won")
    score = score + 1
    compscore = compscore - 1
  else:
    print("You lost")
    score = score - 1
    compscore = compscore + 1
  contin = input("Press x to exit or anything else to continue")
  if contin == "x":
    s = False

print("You got", score)
print("The computer got", compscore)
